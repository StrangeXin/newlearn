# 数据库（本地用 docker-compose 起的 Postgres，映射在主机 5433 端口）
DATABASE_URL="postgresql://newlearn:newlearn@localhost:5433/newlearn?schema=public"

# 打分服务提供方：mock | deepseek
SCORING_PROVIDER="mock"

# DeepSeek（SCORING_PROVIDER=deepseek 时必填；放 .env，切勿入库）
# 模型可选：deepseek-v4-flash（快/省，默认）| deepseek-v4-pro（更强）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# 会话签名密钥（任意长随机串）
AUTH_SECRET="dev-only-change-me-please-32-bytes-min"

# 全员共享默认密码（首登强制改密）
DEFAULT_PASSWORD="Aa123456!"

# 是否强制首登改密（默认开启）；填 false 可临时关闭
REQUIRE_PASSWORD_CHANGE="true"

# 定时结算任务密钥（保护 /api/cron/settle）；Vercel Cron 会自动以 Bearer 形式带上
CRON_SECRET=""

# 关键词手绘配图生成（管理后台「学科与内容」里使用；密钥放 .env，切勿入库）
IMAGE_BASE_URL="https://api.codexzh.com/v1"
IMAGE_API_KEY=""
